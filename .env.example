# Required: Your Anthropic API key
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override the models (defaults work for all standard API keys)
# CLAUDE_FAST_MODEL=claude-3-5-haiku-20241022
# CLAUDE_SMART_MODEL=claude-3-5-sonnet-20241022
#
# If your API key has access to Claude 4 models, you can use:
# CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
# CLAUDE_SMART_MODEL=claude-sonnet-4-6
